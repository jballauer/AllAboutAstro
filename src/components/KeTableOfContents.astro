---
interface Props {
  currentId: string;
}
const { currentId } = Astro.props;

const items = [
  { id: 'all-about-ke-rules', label: 'Introduction' },
  { id: 'all-about-ke-rules/chapter-1-understandings-and-conventions', label: 'Chapter 1: Understandings and Conventions' },
  { id: 'all-about-ke-rules/chapter-2-single-sided-mannheim-type', label: 'Chapter 2: Rules of the Single-Sided, Mannheim-Type' },
  { id: 'all-about-ke-rules/chapter-3-double-sided-duplex-type', label: 'Chapter 3: Rules of the Double-Sided, Duplex-Type' },
  { id: 'all-about-ke-rules/chapter-4-specialty-rules', label: 'Chapter 4: The Specialty Rules' },
  { id: 'all-about-ke-rules/chapter-5-miscellaneous-rules', label: 'Chapter 5: Miscellaneous K&E Rules' },
  { id: 'all-about-ke-rules/chapter-6-out-of-catalog-custom-rules', label: 'Chapter 6: Out of Catalog, Custom Rules' },
  { id: 'all-about-ke-rules/chapter-7-portfolio', label: 'Chapter 7: My Portfolio of K&E Slide Rules' },
  { id: 'all-about-ke-rules/appendix-1-study-of-cases', label: 'Appendix 1: A Study of K&E Cases' },
  { id: 'all-about-ke-rules/appendix-2-study-of-product-catalogs', label: 'Appendix 2: A Study of K&E Product Catalogs' },
  { id: 'all-about-ke-rules/appendix-3-cursor-study', label: 'Appendix 3: A K&E Cursor Study' },
  { id: 'all-about-ke-rules/appendix-4-bibliography', label: 'Appendix 4: Bibliography' },
  { id: 'all-about-ke-rules/appendix-5-version-history', label: 'Appendix 5: Version History' },
];

const hrefFor = (id: string) => id === 'all-about-ke-rules' ? '/sliderules/all-about-ke-rules/' : `/sliderules/${id}/`;
const currentItem = items.find((item) => item.id === currentId);
---

<details class="ke-toc">
  <summary>
    Table of Contents
    {currentItem && <span class="ke-toc-current">— {currentItem.label}</span>}
  </summary>
  <nav aria-label="All About Keuffel & Esser Rules — table of contents">
    <ul>
      {items.map((item) => (
        <li>
          <a href={hrefFor(item.id)} aria-current={item.id === currentId ? 'page' : undefined}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</details>

<style>
  .ke-toc {
    background-color: #1d5f8a;
    color: #fff;
    margin: 0 0 1.5rem;
    box-sizing: border-box;
  }
  .ke-toc summary {
    cursor: pointer;
    padding: 0.75rem 1.1rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    list-style: none;
  }
  .ke-toc summary::-webkit-details-marker {
    display: none;
  }
  .ke-toc summary::before {
    content: '▸ ';
  }
  .ke-toc[open] summary::before {
    content: '▾ ';
  }
  .ke-toc-current {
    font-family: var(--font-body);
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    color: rgba(255, 255, 255, 0.85);
  }
  .ke-toc nav {
    padding: 0 1.1rem 1.1rem;
  }
  .ke-toc ul {
    list-style: none;
    margin: 0;
    padding-top: 0.6rem;
    border-top: 2px dotted rgba(255, 255, 255, 0.5);
    columns: 2;
    column-gap: 2rem;
  }
  .ke-toc li {
    break-inside: avoid;
    margin-bottom: 0.5rem;
  }
  .ke-toc a {
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    line-height: var(--prose-line-height);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: underline;
  }
  .ke-toc a[aria-current='page'] {
    color: #fff;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .ke-toc ul {
      columns: 1;
    }
  }
</style>
