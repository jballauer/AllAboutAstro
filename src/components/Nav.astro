---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Astro Gallery', href: '/gallery/' },
  { label: 'Astro Gear', href: '/gear/' },
  { label: 'Learning', href: '/learning/' },
  { label: 'About Me', href: '/about-me/' },
  { label: "Jay's Slide Rules", href: '/sliderules/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-title" href="/">All About Astro</a>
    <nav aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid #333;
    background: #0b0e14;
  }
  .site-header__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #e8ecf4;
    text-decoration: none;
  }
  nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: #b8c0d0;
    text-decoration: none;
    font-size: 0.95rem;
  }
  nav a:hover,
  nav a[aria-current='page'] {
    color: #e8ecf4;
  }
</style>
