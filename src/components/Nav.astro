---
import { getCollection } from 'astro:content';

const gearItems = (await getCollection('gear')).sort((a, b) => a.data.order - b.data.order);
const learningItems = (await getCollection('learning', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const allSliderules = await getCollection('sliderules');
const sliderulesTop = allSliderules
  .filter((item) => !item.id.includes('/'))
  .sort((a, b) => a.data.order - b.data.order);

const currentPath = Astro.url.pathname;
const isCurrent = (base: string) => currentPath === base || currentPath.startsWith(base);
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-title" href="/">All About Astro.com</a>
    <nav aria-label="Primary">
      <ul>
        <li><a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Home</a></li>
        <li><a href="/blog/" aria-current={isCurrent('/blog/') ? 'page' : undefined}>Blog</a></li>
        <li><a href="/gallery/" aria-current={isCurrent('/gallery/') ? 'page' : undefined}>Astro Gallery</a></li>

        <li class="has-dropdown">
          <a href="/gear/" aria-current={isCurrent('/gear/') ? 'page' : undefined}>Astro Gear</a>
          <ul class="dropdown">
            {gearItems.map((item) => (
              <li><a href={`/gear/${item.id}/`}>{item.data.title}</a></li>
            ))}
          </ul>
        </li>

        <li class="has-dropdown">
          <a href="/learning/" aria-current={isCurrent('/learning/') ? 'page' : undefined}>Learning</a>
          <ul class="dropdown">
            {learningItems.map((item) => (
              <li><a href={`/learning/${item.id}/`}>{item.data.title}</a></li>
            ))}
          </ul>
        </li>

        <li><a href="/about-me/" aria-current={currentPath === '/about-me/' ? 'page' : undefined}>About Me</a></li>

        <li class="has-dropdown dropdown-right">
          <a href="/sliderules/" aria-current={isCurrent('/sliderules/') ? 'page' : undefined}>Jay's Slide Rules</a>
          <ul class="dropdown">
            {sliderulesTop.map((item) => (
              <li><a href={`/sliderules/${item.id}/`}>{item.data.title}</a></li>
            ))}
          </ul>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid #333;
    background-color: #0d0d0e;
    background-image: url('/images/nav-bg.png');
    background-repeat: repeat-x;
    position: relative;
    z-index: 100;
  }
  .site-header__inner {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #e8ecf4;
    text-decoration: none;
  }
  nav > ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
  }
  nav > ul > li {
    position: relative;
  }
  nav a {
    color: #b8c0d0;
    text-decoration: none;
    font-size: 0.95rem;
  }
  nav a:hover,
  nav a[aria-current='page'] {
    color: #e8ecf4;
  }

  .has-dropdown {
    display: flex;
    align-items: center;
  }
  .has-dropdown > a::after {
    content: ' ▾';
    font-size: 0.7rem;
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0;
    background: #12151d;
    border: 1px solid #2a2f3a;
    border-radius: 6px;
    padding: 0.5rem 0;
    width: 260px;
    flex-direction: column;
    gap: 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    list-style: none;
    margin-left: 0;
  }
  .has-dropdown:hover > .dropdown,
  .has-dropdown:focus-within > .dropdown,
  .has-submenu:hover > .dropdown,
  .has-submenu:focus-within > .dropdown {
    display: block;
  }
  .dropdown li {
    position: relative;
  }
  .dropdown a {
    display: block;
    padding: 0.4rem 1rem;
    white-space: normal;
    line-height: 1.3;
    font-size: 0.9rem;
  }
  .dropdown a:hover {
    background: #1b2029;
  }
  .dropdown-right > .dropdown {
    left: auto;
    right: 0;
  }
  .has-submenu > a::after {
    content: ' ◂';
  }
  .submenu {
    top: 0;
    left: auto;
    right: 100%;
    margin-top: 0;
    margin-right: 0;
  }

  @media (max-width: 720px) {
    .dropdown {
      display: block;
      position: static;
      margin-top: 0.25rem;
      margin-left: 1rem;
      box-shadow: none;
    }
    .submenu {
      margin-left: 1rem;
    }
  }
</style>
