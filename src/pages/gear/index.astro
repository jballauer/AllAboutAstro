---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import gearBanner from '../../assets/banners/gear-banner.jpg';
import eq01 from '../../content/gear/_images/eq-01-tsp-2005-rcos-fsq106.jpg';
import eq02 from '../../content/gear/_images/eq-02-cruzen-boys-observatory.jpg';
import eq03 from '../../content/gear/_images/eq-03-eldorado-2005-collimating.jpg';
import eq04 from '../../content/gear/_images/eq-04-triple-threat.jpg';
import eq05 from '../../content/gear/_images/eq-05-toa150-fsq106-piggyback.jpg';
import eq06 from '../../content/gear/_images/eq-06-parme-toa150-esprit120.jpg';
import eq07 from '../../content/gear/_images/eq-07-eclipse-2019-setup.jpg';
import eq08 from '../../content/gear/_images/eq-08-toa150-ap900-stl11000m.jpg';
import eqSig from '../../content/gear/_images/eq-sig-signature.jpg';
import eq09 from '../../content/gear/_images/eq-09-trunk-or-treat-2017.jpg';
import eq09b from '../../content/gear/_images/eq-09b-trunk-or-treat-actual-event.jpg';
import eq10 from '../../content/gear/_images/eq-10-rasa11-parme2.jpg';
import eq11 from '../../content/gear/_images/eq-11-c11edge-mxplus-lespaul.jpg';
import grThumbSoftwareBisque from '../../content/gear/_images/gr-thumb-software-bisque.jpg';

const items = (await getCollection('gear', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

// Thumbnails for the Gear Reviews cards, keyed by content-collection id.
// Reviews without an entry here fall back to a plain text link.
const gearReviewThumbnails: Record<string, ImageMetadata> = {
  'software-bisque-mounts': grThumbSoftwareBisque,
};

// Pulled out of the carousel and placed inline with the essay text below,
// matching where this photo sat on the original page.
const eq08Photo = {
  src: eq08,
  hires: '/images/gear/eq-08-toa150-ap900-stl11000m.jpg',
  alt: 'A Takahashi TOA-150 on an AP900 mount with an SBIG STL-11000m astro camera',
  caption: 'TOA-150, AP900, and SBIG STL-11000m astro camera.',
};

const equipmentPhotos = [
  {
    src: eq01,
    hires: '/images/gear/eq-01-tsp-2005-rcos-fsq106.jpg',
    alt: 'A 12.5" RCOS RC and 4" Takahashi FSQ-106 on a Paramount ME at the 2005 Texas Star Party',
    caption:
      'At the 2005 Texas Star Party - Shown is the 12.5" RCOS RC and 4" Tak FSQ-106 on a Paramount ME. Camera is a SBIG STL-6303E. As of 2017, this exact setup is located in the 3RF Conley Observatory on the Comanche Springs Astronomy Campus near Crowell, Texas.',
  },
  {
    src: eq02,
    hires: '/images/gear/eq-02-cruzen-boys-observatory.jpg',
    alt: 'A Paramount ME2 and Planewave CDK17 with a dog standing watch, for the Cruzen Boys Black Hills Observatory',
    caption:
      'Equipment for the Cruzen Boys Black Hills Observatory - Shut down due to the death of my client, the equipment for the build will be re-purposed. My Greyhound keeps watchful eye on a Paramount ME2 and Planewave CDK17.',
  },
  {
    src: eq03,
    hires: '/images/gear/eq-03-eldorado-2005-collimating.jpg',
    alt: 'Collimating a 12.5" RCOS RC telescope at the 2005 Eldorado Star Party',
    caption: '2005 Eldorado Star Party: Collimating the 12.5" RCOS RC.',
  },
  {
    src: eq04,
    hires: '/images/gear/eq-04-triple-threat.jpg',
    alt: 'A Takahashi TOA-150, Astro-Physics AP160 Starfire, and Sky-Watcher Esprit 150 side by side',
    caption:
      '"Triple Threat" - Having fun with three 6" apos. Shown (from left to right) are a Takahashi TOA-150, Astro-Physics AP160 Starfire, and the Sky-Watcher Esprit 150. I was comparing the Tak and the Sky-Watcher for a Sky-Watcher USA advertisement using the same cameras simultaneously. The AP was the guidescope! Photo taken at CSAC (3RF) near Crowell, Texas.',
  },
  {
    src: eq05,
    hires: '/images/gear/eq-05-toa150-fsq106-piggyback.jpg',
    alt: 'A Takahashi TOA-150 with FSQ-106 riding piggyback, both on an AP-900 mount',
    caption:
      'Takahashi TOA-150 with FSQ-106 riding piggyback, both on a AP-900 mount. Taken at Okie-Star Party around 2006 (I think).',
  },
  {
    src: eq06,
    hires: '/images/gear/eq-06-parme-toa150-esprit120.jpg',
    alt: 'A Paramount ME with a 6" Takahashi TOA-150 and a 5" Sky-Watcher Esprit 120',
    caption:
      'Paramount ME, 6" Tak TOA-150 and a 5" Sky-Watcher Esprit 120. The Tak is my old standby, but I\'m impressed by the value of the Sky-Watcher APOs. A ton of bang for the buck!',
  },
  {
    src: eq07,
    hires: '/images/gear/eq-07-eclipse-2019-setup.jpg',
    alt: 'A Coronado Solar Max 90mm double-stacked telescope and Takahashi FSQ-85ED on a Takahashi NJP Temma 2 mount, set up for the 2019 solar eclipse',
    caption:
      'Setup for the Great Solar Eclipse on August 21, 2019. Coronado Solar Max 90mm Double-Stacked Telescope, Takahashi FSQ-85ED refractor, and Takahashi NJP Temma 2 mount.',
  },
  {
    src: eq09,
    hires: '/images/gear/eq-09-trunk-or-treat-2017.jpg',
    alt: 'Telescope setup for a "Trunk or Treat" outreach event at a friend\'s church, October 2017',
    caption:
      'October 29, 2017 - This will be the setup for "Trunk or Treat" tonight at a friend\'s church. Pictured is the Takahashi TOA-150 for visual and Takahashi FSQ-85 "Baby-Q" with the Nikon D810A, all atop the Takahashi NJP mount. The Nikon, set on LiveView and fed to the laptop display, will give people an idea of what they will see before looking through the eyepiece. This might be the best configuration I can think of for portable, outreach events. Below is the setup at the actual event.',
  },
  {
    src: eq09b,
    hires: '/images/gear/eq-09b-trunk-or-treat-actual-event.jpg',
    alt: 'The Trunk or Treat outreach setup in use at the actual event',
    caption: '',
  },
  {
    src: eq10,
    hires: '/images/gear/eq-10-rasa11-parme2.jpg',
    alt: 'An 11" Celestron RASA atop a Paramount ME2',
    caption: '11" Celestron RASA atop a Paramount ME2, awaiting some time under the stars.',
  },
  {
    src: eq11,
    hires: '/images/gear/eq-11-c11edge-mxplus-lespaul.jpg',
    alt: 'A Celestron C-11 Edge SCT on a Paramount MX+ mount, with a Gibson Les Paul guitar nearby',
    caption:
      'Celestron C-11 Edge SCT with Paramount MX+ mount. Yes, that\'s a 1979 Gibson Les Paul Standard.',
  },
];
---

<BaseLayout title="Astro Gear" description="Equipment - Imaging Gear - Tools - Reviews">
  <article>
  <h1>Astro Gear</h1>
  <p class="tagline">Equipment - Imaging Gear - Tools - Reviews</p>

  <PageBanner src={gearBanner} alt="A close-up of the Optical Systems logo and lens cap" />

  <div class="gear-left-col">
    <h2>Gear Reviews</h2>
    {items.map((item) => {
      const thumb = gearReviewThumbnails[item.id];
      return (
        <div class="ke-gear-review">
          {thumb && (
            <a href={`/gear/${item.id}/`} class="ke-gear-review-thumb">
              <Image src={thumb} alt={item.data.title} width={150} height={150} />
            </a>
          )}
          <p class="ke-gear-review-text">
            <a href={`/gear/${item.id}/`}><strong>{item.data.title}</strong></a>
            {item.data.description && <> - {item.data.description}</>}
          </p>
        </div>
      );
    })}

    <h2>Equipment Images...</h2>
    <p>A snapshot history of just some of the gear that I have employed.</p>

    <div class="gear-carousel">
      <div class="gc-stage">
        <button type="button" class="gc-pause" aria-label="Pause slideshow">Pause ❙❙</button>
        <button type="button" class="gc-prev" aria-label="Previous image">‹</button>
        <button type="button" class="gc-next" aria-label="Next image">›</button>
        {equipmentPhotos.map((photo, i) => (
          <figure class="gc-slide" data-index={i} data-active={i === 0} data-hires={photo.hires} data-caption={photo.caption}>
            <Image src={photo.src} alt={photo.alt} width={700} />
          </figure>
        ))}
      </div>
      <p class="gc-caption">{equipmentPhotos[0].caption}</p>
      <div class="gc-thumbs no-lightbox">
        {equipmentPhotos.map((photo, i) => (
          <Image src={photo.src} alt="" width={90} class="gc-thumb" data-index={i} data-active={i === 0} />
        ))}
      </div>
    </div>
  </div>

  <figure class="ke-figure ke-figure-third ke-figure-right" data-hires={eq08Photo.hires}>
    <Image src={eq08Photo.src} alt={eq08Photo.alt} width={400} />
    <figcaption class="ke-figure-caption">{eq08Photo.caption}</figcaption>
  </figure>

  <p>This hobby is a battlefield, a war in which the attrition rate overwhelms strategic planning and ultimately loses out to the larger force. This is where photon-cannons lose sight of the target amidst sporadically cloudy skies. Where deep-space artillery and targeting scopes, with their sophisticated command software, come together to form a combined-arms attack, only to be demoralized by the more powerful forces of mount error, light pollution, atmospheric anomalies, and light mechanical imprecision – where poorly outfitted armies, bad supplies lies, and dreadful reinforcements are overwhelmed by the shock and awe of a pervasive attack by the enemy on all fronts. Ground to air forces made ineffective against the air superiority of the adversary, leaving the gear to be sold off of Astromart to the highest third-world bidder.</p>

  <p>Astronomy classifieds are like an orphanage, where poor, helpless youths stand in line for adoption by new, prospective parents, only to be redeemed and rejected once again when these children prove too unruly, too time-consuming to handle. Otherwise soulful kids marketed and bargained about like meaningless objects, bouncing from foster home to foster home without ever achieving full potential.</p>

  <p>A more apt description of the difficulties within this hobby you will never find!</p>

  <p>The reasons for the high turnover rate with astronomy gear and the exit from the hobby by well-intentioned, motivated individuals is ultimately very personal, sometimes sad. But the excuses all come from one overriding factor, a lineage that can be traced back to the first branch of the astrophotographic family tree – astroimaging is highly complex and highly variable.</p>

  <p>To have success in this hobby, time, motivation, commitment, and talent are key factors, but NOTHING is more important than solid, reliable equipment. Together, a fusion results, a recipe for winning over the complexities and variables in this hobby.</p>

  <p>Complexities can be overcome through practice and study, much the same way a doctor learns the intricate and immense detail in the human body, or a mechanic optimizes an engine through years of practice and knowledge. Resources (like this website) are available to the astroimager to assist you with the management of the details brought together by such a synergy of hardware and software systems. This is where dedication and commitment exerts a strong will over the understanding required for success. This comprehension is based on known factors; a constant value that normally ramps up in direct proportion to the number of elements your pocketbook purchases, a linear function of the amount of time spent in praxis and learning.</p>

  <p>Ultimately, it's not the complexity that is the problem – that is a challenge that is often well met. Instead, it's the variables – so many parameters can change on a nightly basis.</p>

  <p>At any time during an imaging session, odds are likely that you will run into a performance issue that is not easily understood. For example, when a one-minute image reveals trailed stars, the solution will not be readily apparent, especially to the newly-initiated among us. Rather, any one of several potential issues is possible – and, often, multiple offenders are involved:</p>

  <ul>
    <li>Is the polar alignment good?</li>
    <li>Is there an autoguiding or tracking problem?</li>
    <li>Did the wind blow the scope or the seeing deteriorate?</li>
    <li>Did the focuser shift due to the temperature change or did it just slip?</li>
    <li>Did I snag a cable or did a cosmic ray hit confuse the autoguider?</li>
  </ul>

  <p>The only solution to this interplay of unpredictable circumstances is to know enough about your imaging system in order to identify the roots causes, diminish their effects, or eliminate them entirely. This assumes, of course, that those factors can be addressed at all – Murphy's Law was invented for a reason.</p>

  <p>The solution is to know your imaging gear. This can indeed reduce the amplitude and frequency of your errors. Likewise, more experience, particularly with software tools designed to provide objective methods for troubleshooting your hardware, can allow the astroimager to reduce the impact of most imaging variables.</p>

  <p class="ke-signature">
    <Image src={eqSig} alt="Jay Ballauer's signature" width={220} />
  </p>
  </article>
</BaseLayout>

<style>
  .tagline {
    color: #9aa4b8;
  }
  .ke-gear-review {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .ke-gear-review-thumb {
    flex-shrink: 0;
    display: block;
  }
  .ke-gear-review-thumb img {
    display: block;
    width: 100px;
    height: 100px;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .ke-gear-review-text {
    margin: 0;
  }
  .ke-signature {
    clear: both;
    text-align: center;
    margin: 1.5rem 0;
  }

  .gear-left-col {
    float: left;
    width: 50%;
    margin: 0 1.5rem 1rem 0;
  }
  .gear-carousel {
    margin: 0.3rem 0 1rem;
  }
  .gc-stage {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  @media (max-width: 700px) {
    .gear-left-col {
      float: none;
      width: 100%;
      margin: 0 0 1rem;
    }
  }
  .gc-stage :global(.gc-slide) {
    position: absolute;
    inset: 0;
    margin: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1s ease;
  }
  .gc-stage :global(.gc-slide[data-active='true']) {
    opacity: 1;
    pointer-events: auto;
  }
  .gc-stage :global(.gc-slide img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
  }
  .gc-pause,
  .gc-prev,
  .gc-next {
    position: absolute;
    z-index: 2;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.85rem;
    padding: 0.3rem 0.6rem;
  }
  .gc-pause {
    top: 0.5rem;
    left: 0.5rem;
  }
  .gc-prev,
  .gc-next {
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.25rem;
    padding: 0.3rem 0.75rem;
  }
  .gc-prev {
    left: 0.5rem;
  }
  .gc-next {
    right: 0.5rem;
  }
  .gc-caption {
    margin: 0.6rem 0 0;
    font-style: italic;
    color: #9aa4b8;
    text-align: center;
    min-height: 1.4em;
  }
  .gc-thumbs {
    display: flex;
    flex-wrap: nowrap;
    gap: 6px;
    overflow-x: auto;
    margin: 0.6rem 0 0;
  }
  .gc-thumbs :global(.gc-thumb) {
    flex-shrink: 0;
    width: 90px;
    height: 63px;
    object-fit: cover;
    cursor: pointer;
    opacity: 0.6;
  }
  .gc-thumbs :global(.gc-thumb[data-active='true']) {
    opacity: 1;
    outline: 2px solid var(--color-link);
  }
</style>

<script>
  const carousel = document.querySelector('.gear-carousel');
  if (carousel) {
    const stage = carousel.querySelector('.gc-stage') as HTMLElement;
    const slides = Array.from(stage.querySelectorAll<HTMLElement>('.gc-slide'));
    const thumbs = Array.from(carousel.querySelectorAll<HTMLElement>('.gc-thumb'));
    const thumbsEl = carousel.querySelector('.gc-thumbs') as HTMLElement;
    const captionEl = carousel.querySelector('.gc-caption') as HTMLElement;
    const pauseBtn = carousel.querySelector('.gc-pause') as HTMLButtonElement;
    const prevBtn = carousel.querySelector('.gc-prev') as HTMLButtonElement;
    const nextBtn = carousel.querySelector('.gc-next') as HTMLButtonElement;
    let current = 0;
    let playing = true;
    let timer: ReturnType<typeof setInterval> | undefined;

    function scrollThumbIntoView(thumb: HTMLElement) {
      const thumbLeft = thumb.offsetLeft;
      const thumbRight = thumbLeft + thumb.offsetWidth;
      const viewLeft = thumbsEl.scrollLeft;
      const viewRight = viewLeft + thumbsEl.clientWidth;
      if (thumbLeft < viewLeft) {
        thumbsEl.scrollLeft = thumbLeft;
      } else if (thumbRight > viewRight) {
        thumbsEl.scrollLeft = thumbRight - thumbsEl.clientWidth;
      }
    }

    function show(index: number) {
      slides[current].setAttribute('data-active', 'false');
      thumbs[current].setAttribute('data-active', 'false');
      current = (index + slides.length) % slides.length;
      slides[current].setAttribute('data-active', 'true');
      thumbs[current].setAttribute('data-active', 'true');
      captionEl.textContent = slides[current].dataset.caption || '';
      scrollThumbIntoView(thumbs[current]);
    }

    function start() {
      timer = setInterval(() => show(current + 1), 5000);
    }
    function stop() {
      if (timer) clearInterval(timer);
    }

    start();

    pauseBtn.addEventListener('click', () => {
      playing = !playing;
      pauseBtn.textContent = playing ? 'Pause ❙❙' : 'Play ►';
      if (playing) {
        start();
      } else {
        stop();
      }
    });
    prevBtn.addEventListener('click', () => {
      show(current - 1);
      if (playing) { stop(); start(); }
    });
    nextBtn.addEventListener('click', () => {
      show(current + 1);
      if (playing) { stop(); start(); }
    });
    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => {
        show(i);
        if (playing) { stop(); start(); }
      });
    });

    thumbsEl.addEventListener('wheel', (event: WheelEvent) => {
      if (Math.abs(event.deltaY) > Math.abs(event.deltaX)) {
        event.preventDefault();
        thumbsEl.scrollLeft += event.deltaY;
      }
    });
  }
</script>
