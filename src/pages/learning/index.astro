---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import { getCollection } from 'astro:content';
import learningBanner from '../../assets/banners/learning-banner.png';

const articles = (await getCollection('learning', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Learning">
  <PageBanner src={learningBanner} alt="A close-up collage of the Pillars of Creation in the Eagle Nebula" />
  <h1>Learning</h1>
  <ul>
    {articles.map((article) => (
      <li>
        <a href={`/learning/${article.id}/`}>{article.data.title}</a>
      </li>
    ))}
  </ul>
</BaseLayout>
