---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import KeTableOfContents from '../../components/KeTableOfContents.astro';
import signatureImage from '../../assets/home/signature-transparent.png';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('sliderules');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const isKeSubPage = entry.id.startsWith('all-about-ke-rules/');
// The K&E Rules piece is one article split across a landing page + many
// chapter/appendix pages — the closing signature belongs only at the true
// end of an article, not at the bottom of every split-out page.
const isKePage = entry.id === 'all-about-ke-rules' || isKeSubPage;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article>
    <h1>{entry.data.title}</h1>
    {isKeSubPage && <KeTableOfContents currentId={entry.id} />}
    <Content />
    {!isKePage && (
      <>
        <div class="ke-clear"></div>
        <Image src={signatureImage} alt="Jay Ballauer's signature" width={139} class="article-signature" />
      </>
    )}
  </article>
</BaseLayout>

<style>
  .article-signature {
    display: block;
    margin: 1.5rem 0 0 auto;
  }
</style>
