---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBanner from '../../components/PageBanner.astro';
import KeTableOfContents from '../../components/KeTableOfContents.astro';
import signatureImage from '../../assets/home/signature-transparent.png';
import myFavoriteSlideRulesBanner from '../../assets/banners/my-favorite-slide-rules-banner.jpg';
import pickettBanner from '../../assets/banners/pickett-banner.jpg';
import educationalValueBanner from '../../assets/banners/educational-value-banner.jpg';
import keBanner from '../../content/sliderules/_images/ke-banner-decilon5.jpg';
import { getCollection, render } from 'astro:content';
import { getLastUpdated } from '../../utils/lastUpdated.js';

// Landing/article pages that had their own distinct header banner on the
// original site. Every one of these must render above the <h1>, immediately
// below the navbar — same rule for every page site-wide.
const pageBanners: Record<string, { src: ImageMetadata; alt: string }> = {
  'my-favorite-slide-rules': {
    src: myFavoriteSlideRulesBanner,
    alt: 'A close-up of a Keuffel & Esser Celanese Celcon slide rule',
  },
  pickett: {
    src: pickettBanner,
    alt: 'A close-up of the back of a Pickett Model C-19 slide rule',
  },
  'the-educational-value-of-slide-rules': {
    src: educationalValueBanner,
    alt: 'A close-up of a slide rule',
  },
  'all-about-ke-rules': {
    src: keBanner,
    alt: 'A close-up of a K&E Deci-Lon slide rule',
  },
};

export async function getStaticPaths() {
  const entries = await getCollection('sliderules');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const isKeSubPage = entry.id.startsWith('all-about-ke-rules/');
// The K&E Rules piece is one article split across a landing page + many
// chapter/appendix pages — the closing signature belongs only at the true
// end of an article, not at the bottom of every split-out page.
const isKePage = entry.id === 'all-about-ke-rules' || isKeSubPage;
const isKeLandingPage = entry.id === 'all-about-ke-rules';
const keLastUpdated = isKeLandingPage
  ? getLastUpdated('src/content/sliderules/all-about-ke-rules')
  : null;
const banner = pageBanners[entry.id];
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article>
    {banner && <PageBanner src={banner.src} alt={banner.alt} />}
    <h1>{entry.data.title}</h1>
    {keLastUpdated && (
      <p class="ke-last-updated">Last updated: {keLastUpdated}</p>
    )}
    {isKeSubPage && <KeTableOfContents currentId={entry.id} />}
    <Content />
    {!isKePage && (
      <>
        <div class="ke-clear"></div>
        <Image src={signatureImage} alt="Jay Ballauer's signature" width={139} class="article-signature" />
      </>
    )}
  </article>
</BaseLayout>

<style>
  .article-signature {
    display: block;
    margin: 1.5rem 0 0 auto;
  }

  .ke-last-updated {
    display: inline-block;
    margin: 0 0 1.25rem;
    padding: 0.35rem 0.85rem;
    border-left: 4px solid #b3261e;
    background: #fdf1ef;
    color: #6b1410;
    font-family: Arial, Helvetica, sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
  }
</style>
