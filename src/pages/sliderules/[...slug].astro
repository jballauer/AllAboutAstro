---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KeTableOfContents from '../../components/KeTableOfContents.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('sliderules');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const isKeSubPage = entry.id.startsWith('all-about-ke-rules/');
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article>
    <h1>{entry.data.title}</h1>
    {isKeSubPage && <KeTableOfContents currentId={entry.id} />}
    <Content />
  </article>
</BaseLayout>
