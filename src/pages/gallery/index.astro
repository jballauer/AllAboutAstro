---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const images = (await getCollection('gallery', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Astro Gallery">
  <h1>Astro Gallery</h1>
  <div class="grid">
    {images.map((entry) => (
      <a class="tile" href={`/gallery/${entry.id}/`}>
        {entry.data.image && <Image src={entry.data.image} alt={entry.data.title} width={400} height={400} />}
        <span>{entry.data.title}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .tile {
    color: inherit;
    text-decoration: none;
  }
  .tile span {
    display: block;
    margin-top: 0.5rem;
  }
</style>
