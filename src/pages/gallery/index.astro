---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const images = (await getCollection('gallery', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Square thumbnail crops center by default, which works fine for the
// site's typically near-square astrophotos. A non-square source (e.g. a
// 16:9 video-frame thumbnail) needs an explicit crop position so the
// subject doesn't get cut off -- see the comet-neowise-timelapse entry.
const thumbPosition: Record<string, string> = {
  'comet-neowise-timelapse': 'left',
};
---

<BaseLayout title="Astro Gallery">
  <h1>Astrophotography by Jay Ballauer</h1>
  <p>Here is a selection of just some of the images I have taken over the many years of pointing a telescope at the night sky. For the most part, they are taken with a wide variety of apochromatic refractors, ranging from 3" to 6", with narrow-field images taken with a 12.5" RCOS RC. A variety of cameras are used and you can assume that the images are from a cooled astro CCD unless otherwise indicated in the title. Clicking on any of the images will bring up a separate page with more information about it. My goal is to add more images over time, as well as provide more of the individual pages full of details about them.</p>
  <p>Some images also include an interactive slider below them &mdash; drag it to reveal the stars in that photo, labeled with their name and magnitude, straight from real astronomical catalogs.</p>
  <div class="grid">
    {images.map((entry) => (
      <a class="tile" href={`/gallery/${entry.id}/`}>
        {entry.data.image && (
          <span class="tile-image">
            <Image
              src={entry.data.image}
              alt=""
              width={400}
              height={300}
              position={thumbPosition[entry.id]}
            />
            <span class="tile-caption">{entry.data.title}</span>
          </span>
        )}
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .tile {
    color: inherit;
    text-decoration: none;
  }
  /* 4:3 crop (close to the site's typical astrophoto proportions --
     3:2 to 4:3 in practice) instead of a full square, so less of each
     photo needs to be cropped away than a 1:1 thumbnail would require. */
  .tile-image {
    position: relative;
    display: block;
  }
  .tile-image :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }
  /* Caption overlaid directly on the image, bottom-anchored, capped at
     1/4 of the image's own height so it stays a minor accent rather than
     covering a third of the photo. */
  .tile-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 25%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 0.6rem;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.2;
  }
</style>
