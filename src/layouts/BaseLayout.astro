---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import UnderConstructionStamp from '../components/UnderConstructionStamp.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'All About Astro — astrophotography, gear, and learning resources.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="description" content={description} />
    <title>{title} | All About Astro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav />
    <main>
      <UnderConstructionStamp />
      <slot />
    </main>
    <Footer />
    <div id="ke-lightbox" class="ke-lightbox" hidden>
      <img id="ke-lightbox-img" alt="" />
    </div>
  </body>
</html>

<script>
  // Two zoom mechanisms coexist for now:
  //
  // 1. The in-frame zoom/pan/toggle below — currently opt-in only, via the
  //    `.ke-zoom-inframe` class, while it's being trialed on a single image
  //    (the M31 Mosaic gallery page). Do NOT broaden its selector to
  //    `article img` again without checking with Jay first — see
  //    feedback_lightbox_native_size_pan memory.
  // 2. The plain fullscreen click-to-enlarge lightbox further down, which
  //    is what every other image on the site still uses.

  // In-place zoom: clicking an image zooms in *within its own on-page
  // frame* (never a fullscreen overlay) anchored so the exact pixel
  // clicked stays under the cursor, then lets you drag to pan since the
  // whole image is no longer visible at once. Clicking again returns to
  // the normal fit view. A wrapper span (`display: contents` until
  // active, so it has zero layout effect on the unzoomed page) captures
  // the image's own current rendered box in pixels the instant zoom
  // starts — this works regardless of whether the image lives in a
  // percentage-width float, a flex item, or the absolutely-positioned
  // carousel stage, without needing special-case CSS for each.
  function clamp(value: number, min: number, max: number) {
    return Math.max(min, Math.min(max, value));
  }

  type ZoomState = {
    zoomed: boolean;
    scale: number;
    tx: number;
    ty: number;
    frameW: number;
    frameH: number;
  };

  const allZoomContexts: { state: ZoomState; exitZoom: () => void }[] = [];

  let activeDrag: {
    img: HTMLImageElement;
    frame: HTMLElement;
    state: ZoomState;
    startX: number;
    startY: number;
    originTx: number;
    originTy: number;
    moved: boolean;
  } | null = null;
  let suppressClick = false;

  window.addEventListener('mousemove', (e) => {
    if (!activeDrag) return;
    const dx = e.pageX - activeDrag.startX;
    const dy = e.pageY - activeDrag.startY;
    if (Math.abs(dx) > 3 || Math.abs(dy) > 3) activeDrag.moved = true;
    const { state, img } = activeDrag;
    const tx = clamp(activeDrag.originTx + dx, state.frameW * (1 - state.scale), 0);
    const ty = clamp(activeDrag.originTy + dy, state.frameH * (1 - state.scale), 0);
    state.tx = tx;
    state.ty = ty;
    img.classList.add('ke-zoom-instant');
    img.style.transform = `translate(${tx}px, ${ty}px) scale(${state.scale})`;
  });

  window.addEventListener('mouseup', () => {
    if (activeDrag) {
      if (activeDrag.moved) suppressClick = true;
      activeDrag.img.classList.remove('ke-zoom-instant');
      activeDrag.frame.classList.remove('ke-panning');
      activeDrag.img.style.cursor = 'grab';
    }
    activeDrag = null;
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      allZoomContexts.forEach((ctx) => {
        if (ctx.state.zoomed) ctx.exitZoom();
      });
    }
  });

  function setupZoomFrame(imgEl: Element) {
    const img = imgEl as HTMLImageElement;
    img.classList.add('ke-zoomable');

    const frame = document.createElement('span');
    frame.className = 'ke-zoom-frame';
    img.parentNode?.insertBefore(frame, img);
    frame.appendChild(img);

    const state: ZoomState = { zoomed: false, scale: 1, tx: 0, ty: 0, frameW: 0, frameH: 0 };

    function applyScale(rect: DOMRect, clickX: number, clickY: number, fracX: number, fracY: number, instant: boolean) {
      const natural = img.naturalWidth || rect.width * 2.5;
      const scale = clamp(natural / rect.width, 1.4, 6);
      const tx = clamp(clickX - fracX * rect.width * scale, rect.width * (1 - scale), 0);
      const ty = clamp(clickY - fracY * rect.height * scale, rect.height * (1 - scale), 0);
      state.scale = scale;
      state.tx = tx;
      state.ty = ty;
      if (instant) img.classList.add('ke-zoom-instant');
      img.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
      if (instant) {
        void img.offsetWidth; // force layout so the instant snap applies
        img.classList.remove('ke-zoom-instant');
      }
    }

    function enterZoom(clickX: number, clickY: number) {
      const rect = img.getBoundingClientRect();
      state.frameW = rect.width;
      state.frameH = rect.height;

      // Lock the frame to the image's own current on-page box (in px) and
      // pull the image out to fill it exactly — from here the transform
      // does all the zooming, so it never spills past this box.
      frame.classList.add('ke-zoom-active');
      frame.style.width = `${rect.width}px`;
      frame.style.height = `${rect.height}px`;
      img.classList.add('ke-zoom-img-active');

      const fracX = clamp(clickX / rect.width, 0, 1);
      const fracY = clamp(clickY / rect.height, 0, 1);

      const hiresHost = img.closest<HTMLElement>('[data-hires]');
      const hiresSrc = hiresHost?.dataset.hires;
      const resolvedHiresUrl = hiresSrc ? new URL(hiresSrc, location.href).href : null;

      if (resolvedHiresUrl && img.src !== resolvedHiresUrl) {
        // Grow immediately using the already-loaded small image, then
        // refine the scale once the hi-res file finishes loading.
        applyScale(rect, clickX, clickY, fracX, fracY, false);
        img.addEventListener('load', () => applyScale(rect, clickX, clickY, fracX, fracY, true), { once: true });
        img.src = hiresSrc as string;
      } else {
        applyScale(rect, clickX, clickY, fracX, fracY, false);
      }

      img.style.cursor = 'grab';
      state.zoomed = true;
    }

    function exitZoom() {
      img.style.transform = 'translate(0px, 0px) scale(1)';
      img.style.cursor = '';
      state.zoomed = false;
      window.setTimeout(() => {
        if (!state.zoomed) {
          frame.classList.remove('ke-zoom-active');
          frame.style.width = '';
          frame.style.height = '';
          img.classList.remove('ke-zoom-img-active');
          img.style.transform = '';
        }
      }, 320);
    }

    allZoomContexts.push({ state, exitZoom });

    frame.addEventListener('mousedown', (e) => {
      if (!state.zoomed) return;
      activeDrag = {
        img,
        frame,
        state,
        startX: e.pageX,
        startY: e.pageY,
        originTx: state.tx,
        originTy: state.ty,
        moved: false,
      };
      frame.classList.add('ke-panning');
      img.style.cursor = 'grabbing';
      e.preventDefault();
    });

    frame.addEventListener('click', (e) => {
      if (suppressClick) {
        suppressClick = false;
        return;
      }
      if (state.zoomed) {
        exitZoom();
      } else {
        const rect = img.getBoundingClientRect();
        enterZoom(e.clientX - rect.left, e.clientY - rect.top);
      }
    });
  }

  // Opt-in only for now — see the note at the top of this script block.
  document.querySelectorAll('article img.ke-zoom-inframe').forEach(setupZoomFrame);

  // Plain fullscreen click-to-enlarge lightbox — the default for every
  // other image on the site (unchanged from the original implementation).
  const overlay = document.getElementById('ke-lightbox') as HTMLDivElement;
  const overlayImg = document.getElementById('ke-lightbox-img') as HTMLImageElement;

  function openLightbox(fullSrc: string, alt: string) {
    overlayImg.src = fullSrc;
    overlayImg.alt = alt;
    overlay.hidden = false;
  }

  function closeLightbox() {
    overlay.hidden = true;
    overlayImg.src = '';
  }

  document.querySelectorAll('article img').forEach((img) => {
    if (img.classList.contains('ke-zoom-inframe')) return; // handled above instead
    // Portfolio thumbnails live inside a <summary> and their click should
    // only toggle the accordion, not fight it for the same click by also
    // popping the lightbox open.
    if (img.closest('summary')) return;
    // Carousel thumbnail strips (e.g. the gear-page slideshow) navigate the
    // carousel on click rather than opening the full-res zoom.
    if (img.closest('.no-lightbox')) return;
    img.classList.add('ke-zoomable');
    img.addEventListener('click', () => {
      const hiresHost = img.closest<HTMLElement>('[data-hires]');
      const fullSrc = hiresHost?.dataset.hires || (img as HTMLImageElement).currentSrc || (img as HTMLImageElement).src;
      openLightbox(fullSrc, (img as HTMLImageElement).alt);
    });
  });

  overlay.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style is:global>
  :root {
    color-scheme: dark;

    /* layout */
    --container-width: 960px;

    /* page chrome */
    --color-bg: #0f0f0f;
    --color-text: #dfe4ee;
    --color-link-chrome: #7cb8ff;

    /* prose/article typography (Weebly-confirmed) */
    --font-heading: 'Titillium Web', sans-serif;
    --font-heading-weight: 300;
    --font-heading-size: 24px;
    --color-heading: #ffffff;

    --font-body: Arial, Helvetica, sans-serif;
    --font-body-size: 14px;
    --prose-line-height: 1.5;
    --color-prose-text: #aaaaaa;
    --color-link: #359bdc;

    /* aside/callout boxes (Weebly-confirmed) */
    --aside-color-teal: rgba(51, 135, 162, 0.6);
    --aside-color-orange: rgba(218, 128, 68, 0.6);
    --aside-padding: 20px;
    --aside-width-default: 420px;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
    background-color: var(--color-bg);
    background-image: url('/images/banner-footer.png');
    background-repeat: repeat;
    color: var(--color-text);
    line-height: 1.6;
  }
  main {
    position: relative;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    min-height: 60vh;
    background-color: var(--color-bg);
    background-image: url('/images/body-bg.png');
    background-repeat: repeat-x;
    /* Contain any floated sidebars/figures left active by an article so the
       footer that follows always starts full-width below them, never beside
       a still-open float. */
    display: flow-root;
  }
  a {
    color: var(--color-link-chrome);
  }
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  th, td {
    border: 1px solid #333;
    padding: 0.4rem 0.6rem;
    text-align: left;
  }
  th {
    background: #12151d;
  }
  blockquote {
    border-left: 3px solid #333;
    margin: 1.5rem 0;
    padding: 0.25rem 1.25rem;
    color: #b8c0d0;
  }
  /* Magazine-style pull-quote: a call-out repeating/summarizing a nearby
     line, set apart with rules above and below and a much larger size —
     not a typical indented quotation block. Opt in with class="ke-callout";
     the plain blockquote above stays the default for genuine quotations
     (e.g. a long anecdote or a historical rule inscription) where this
     large centered treatment would be wrong. */
  blockquote.ke-callout {
    border-left: none;
    margin: 2rem 0;
    padding: 1.1rem 0.5rem;
    border-top: 2px solid var(--color-heading);
    border-bottom: 2px solid var(--color-heading);
    font-family: var(--font-heading);
    font-weight: 400;
    font-style: italic;
    font-size: 1.6rem;
    line-height: 1.35;
    text-align: center;
    color: var(--color-heading);
  }
  blockquote.ke-callout p {
    margin: 0;
  }

  /* shared callout-box visual (Weebly "colored box" widget) — used by
     Aside.astro (floated, article prose) and by page-specific multi-column
     layouts (e.g. the home page's "Most Recent Images" widget column) */
  .callout-box {
    padding: var(--aside-padding);
    box-sizing: border-box;
  }
  .callout-box[data-color='teal'] {
    background-color: #2a2a2a;
    background-image: linear-gradient(var(--aside-color-teal), var(--aside-color-teal));
  }
  .callout-box[data-color='orange'] {
    background-color: #2a2a2a;
    background-image: linear-gradient(var(--aside-color-orange), var(--aside-color-orange));
  }
  .callout-box h2 {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: var(--font-heading-size);
    color: var(--color-heading);
    margin-top: 0;
  }

  /* K&E book-style sidebar — modeled on "The Backyard Astronomer's Guide"
     (Dickinson & Dyer): a solid, confident color block with a bold
     all-caps title and a rule underneath, rather than the softer
     translucent callout-box used elsewhere. Used only in K&E content. */
  .ke-sidebar {
    background-color: #1d5f8a;
    color: #fff;
    padding: 20px;
    margin: 0.3rem 0 1rem;
    box-sizing: border-box;
    float: left;
    width: 38%;
    margin-right: 1.75rem;
  }
  .ke-sidebar[data-color='orange'] {
    background-color: #a85a2a;
  }
  .ke-sidebar[data-side='right'] {
    float: right;
    margin-right: 0;
    margin-left: 1.75rem;
  }
  /* A wider variant (roughly two-thirds of the article) for sidebars with a
     lot of their own content — cuts their rendered height by wrapping less,
     while still leaving a real column of body text to run alongside it. */
  .ke-sidebar[data-width='wide'] {
    width: 58%;
  }
  /* Wider still, for a sidebar so packed with content that even "wide"
     leaves it trailing below the article's actual last line of body text —
     Jay's rule is that main text should always be what's "left over" at
     the bottom, never a sidebar hanging past it. */
  .ke-sidebar[data-width='widest'] {
    width: 68%;
  }
  /* Full-width variant — an explicit exception to the normal side-only
     sidebar rule, for a closing addendum/aside with nothing left to wrap
     text beside it (would otherwise leave a large blank column). */
  .ke-sidebar[data-width='full'] {
    float: none;
    clear: both;
    width: 100%;
    margin-left: 0;
    margin-right: 0;
  }
  /* Centered, non-floated half-width variant — for a closing box that
     shouldn't span the full article width (that's reserved for plain body
     text, per site rule) but also has nothing left to wrap beside it. */
  .ke-sidebar[data-width='half'] {
    float: none;
    clear: both;
    width: 60%;
    margin-left: auto;
    margin-right: auto;
  }
  @media (max-width: 700px) {
    .ke-sidebar,
    .ke-sidebar[data-width='half'] {
      float: none;
      width: 100%;
      margin-right: 0;
      margin-left: 0;
    }
  }
  .ke-sidebar h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 0.9rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px dotted rgba(255, 255, 255, 0.5);
  }
  .ke-sidebar p {
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    line-height: var(--prose-line-height);
    color: rgba(255, 255, 255, 0.92);
  }
  .ke-sidebar a {
    color: #fff;
    text-decoration: underline;
  }

  /* K&E numbered image gallery — a grouped set of related photos inside
     a .ke-sidebar, each tagged with a number that matches its caption
     in the list below it. */
  .ke-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
    margin-bottom: 1rem;
  }
  .ke-gallery figure {
    position: relative;
    margin: 0;
  }
  .ke-gallery .ke-gallery-number {
    position: absolute;
    bottom: 6px;
    left: 6px;
    background: rgba(0, 0, 0, 0.65);
    color: #fff;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    font-family: var(--font-body);
  }
  .ke-gallery-captions {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .ke-gallery-captions li {
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    line-height: var(--prose-line-height);
    color: rgba(255, 255, 255, 0.92);
    margin-bottom: 0.6rem;
  }
  .ke-gallery-captions .num {
    font-weight: 700;
    color: #fff;
  }

  /* K&E in-line floated figures — Jay's original Weebly build floated one
     image per text box at half or third width, with text justifying
     around it; this replicates that instead of full-width block images
     breaking up a single column. */
  .ke-figure {
    margin-bottom: 1rem;
  }
  .ke-figure img {
    margin: 0 auto;
  }
  .ke-figure-caption {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-prose-text);
    margin-top: 0.4rem;
    text-align: center;
  }
  .ke-figure-left {
    float: left;
    width: 46%;
    margin: 0.3rem 1.5rem 1rem 0;
  }
  .ke-figure-right {
    float: right;
    width: 46%;
    margin: 0.3rem 0 1rem 1.5rem;
  }
  .ke-figure-third.ke-figure-left,
  .ke-figure-third.ke-figure-right {
    width: 31%;
  }
  /* Smaller preset for a figure that must float opposite a sidebar that's
     still active nearby — a "third" is too wide once a sidebar has also
     claimed part of the row, squeezing body text into the leftover middle
     strip. This leaves enough room for real wrapped text beside both. */
  .ke-figure-quarter.ke-figure-left,
  .ke-figure-quarter.ke-figure-right {
    width: 22%;
  }
  /* A plain (non-floated) figure is a block-level replaced element that
     stays anchored to the container's own edge regardless of width — it
     does not shift sideways to sit beside an active float, so narrowing it
     alone still leaves it overlapping a wide sidebar and gets deferred
     below it entirely (relocating the "void" rather than fixing it). This
     variant floats instead, at a width just under the space left over next
     to a `data-width="wide"` sidebar (~58% + gutter, leaving ~39%), so it
     tucks in beside the sidebar immediately, full-width of that remaining
     column, with too little left over for body text to wrap into a
     cramped sliver beside it. */
  .ke-figure-column {
    float: left;
    /* Match the column left over next to a wide sidebar (100% - 58% - its
       1.75rem gutter) as closely as possible — a narrower figure leaves a
       useless sliver next to it that body text still tries to wrap into,
       recreating the one-word-per-line bug this class exists to avoid. */
    width: calc(42% - 1.75rem - 2px);
    margin: 0.3rem 0 1rem 0;
  }
  .ke-clear {
    clear: both;
  }
  .ke-figure-row {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .ke-figure-row .ke-figure {
    flex: 1;
    margin-bottom: 0;
  }

  /* Unified "feature" gallery: several related photos (e.g. front/back/manual
     of one product) arranged in a single row inside a light frame, sharing
     ONE caption instead of each repeating context in its own — used when no
     single image is tall enough to fill a column on its own, so floating
     each individually just leaves a void beside the short ones. */
  .ke-image-feature {
    clear: both;
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }
  .ke-image-feature-row {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ke-image-feature-row .ke-image-feature-item {
    flex: 1;
    min-width: 110px;
  }
  /* Stacks two related shots (e.g. front/back of the same object) in one
     column so the gallery can pair them against a third, differently-shaped
     image without leaving void space around the shorter items — flex ratio
     vs. the sibling item is tuned per use to roughly match combined heights. */
  .ke-image-feature-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1.7;
    min-width: 110px;
  }
  .ke-image-feature-row img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
  }
  .ke-image-feature-row p {
    margin: 0;
  }
  .ke-image-feature-caption {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-prose-text);
    text-align: center;
    margin: 0.75rem 0 0;
  }
  @media (max-width: 700px) {
    .ke-image-feature-row {
      flex-direction: column;
    }
    .ke-image-feature-row .ke-image-feature-item {
      min-width: 0;
    }
    .ke-image-feature-col {
      min-width: 0;
    }
  }

  /* K&E "scale set" box — Jay's rules routinely quote a scale layout like
     "Front Side: DF [CF, C] D" / "Back Side: CI, D". These previously
     rendered as plain flowing prose (a literal newline in the markdown,
     which HTML collapses to a space — the "two lines" only ever appeared
     by incidental text-wrap at narrow widths). This gives that reference
     data its own quiet, technical-reading treatment: a translucent tint of
     the site's existing teal aside color (distinct from the confident solid
     `.ke-sidebar` blue and the violet `.ke-ai-stub`), monospace for the
     scale notation itself, and one guaranteed line per side regardless of
     viewport width. */
  .ke-scale-set {
    background-color: rgba(51, 135, 162, 0.12);
    border: 1px solid rgba(51, 135, 162, 0.45);
    border-radius: 6px;
    padding: 0.9rem 1.1rem;
    margin: 1.25rem 0;
    /* Deliberately no `clear: both` — unlike `.ke-image-feature` (always a
       deliberate full-width break), a scale-set box can legitimately fall
       while a `.ke-sidebar` is still active nearby, same as the plain
       paragraph it replaces. Clearing here would force a wait for the
       sidebar's full height even when the right-hand column still has real
       body text to squeeze beside — see feedback-ke-layout-rules rule 12. */
  }
  .ke-scale-set-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    line-height: var(--prose-line-height);
  }
  .ke-scale-set-row + .ke-scale-set-row {
    margin-top: 0.4rem;
  }
  .ke-scale-set-label {
    flex-shrink: 0;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
