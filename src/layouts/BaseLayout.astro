---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import UnderConstructionStamp from '../components/UnderConstructionStamp.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'All About Astro — astrophotography, gear, and learning resources.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="description" content={description} />
    <title>{title} | All About Astro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav />
    <main>
      <UnderConstructionStamp />
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;

    /* layout */
    --container-width: 960px;

    /* page chrome */
    --color-bg: #0f0f0f;
    --color-text: #dfe4ee;
    --color-link-chrome: #7cb8ff;

    /* prose/article typography (Weebly-confirmed) */
    --font-heading: 'Titillium Web', sans-serif;
    --font-heading-weight: 300;
    --font-heading-size: 24px;
    --color-heading: #ffffff;

    --font-body: Arial, Helvetica, sans-serif;
    --font-body-size: 14px;
    --prose-line-height: 1.5;
    --color-prose-text: #aaaaaa;
    --color-link: #359bdc;

    /* aside/callout boxes (Weebly-confirmed) */
    --aside-color-teal: rgba(51, 135, 162, 0.6);
    --aside-color-orange: rgba(218, 128, 68, 0.6);
    --aside-padding: 20px;
    --aside-width-default: 420px;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
    background-color: var(--color-bg);
    background-image: url('/images/banner-footer.png');
    background-repeat: repeat;
    color: var(--color-text);
    line-height: 1.6;
  }
  main {
    position: relative;
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    min-height: 60vh;
    background-color: var(--color-bg);
    background-image: url('/images/body-bg.png');
    background-repeat: repeat-x;
  }
  a {
    color: var(--color-link-chrome);
  }
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  th, td {
    border: 1px solid #333;
    padding: 0.4rem 0.6rem;
    text-align: left;
  }
  th {
    background: #12151d;
  }
  blockquote {
    border-left: 3px solid #333;
    margin: 1.5rem 0;
    padding: 0.25rem 1.25rem;
    color: #b8c0d0;
  }

  /* shared callout-box visual (Weebly "colored box" widget) — used by
     Aside.astro (floated, article prose) and by page-specific multi-column
     layouts (e.g. the home page's "Most Recent Images" widget column) */
  .callout-box {
    padding: var(--aside-padding);
    box-sizing: border-box;
  }
  .callout-box[data-color='teal'] {
    background-color: #2a2a2a;
    background-image: linear-gradient(var(--aside-color-teal), var(--aside-color-teal));
  }
  .callout-box[data-color='orange'] {
    background-color: #2a2a2a;
    background-image: linear-gradient(var(--aside-color-orange), var(--aside-color-orange));
  }
  .callout-box :global(h2),
  .callout-box h2 {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: var(--font-heading-size);
    color: var(--color-heading);
    margin-top: 0;
  }

  /* K&E book-style sidebar — modeled on "The Backyard Astronomer's Guide"
     (Dickinson & Dyer): a solid, confident color block with a bold
     all-caps title and a rule underneath, rather than the softer
     translucent callout-box used elsewhere. Used only in K&E content. */
  .ke-sidebar {
    background-color: #1d5f8a;
    color: #fff;
    padding: 20px;
    margin: 0.3rem 0 1rem;
    box-sizing: border-box;
    float: left;
    width: 38%;
    margin-right: 1.75rem;
  }
  .ke-sidebar[data-color='orange'] {
    background-color: #a85a2a;
  }
  .ke-sidebar[data-side='right'] {
    float: right;
    margin-right: 0;
    margin-left: 1.75rem;
  }
  @media (max-width: 700px) {
    .ke-sidebar {
      float: none;
      width: 100%;
      margin-right: 0;
      margin-left: 0;
    }
  }
  .ke-sidebar :global(h2),
  .ke-sidebar h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 0.9rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px dotted rgba(255, 255, 255, 0.5);
  }
  .ke-sidebar :global(p),
  .ke-sidebar p {
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    line-height: var(--prose-line-height);
    color: rgba(255, 255, 255, 0.92);
  }
  .ke-sidebar :global(a),
  .ke-sidebar a {
    color: #fff;
    text-decoration: underline;
  }

  /* K&E numbered image gallery — a grouped set of related photos inside
     a .ke-sidebar, each tagged with a number that matches its caption
     in the list below it. */
  .ke-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
    margin-bottom: 1rem;
  }
  .ke-gallery figure {
    position: relative;
    margin: 0;
  }
  .ke-gallery .ke-gallery-number {
    position: absolute;
    bottom: 6px;
    left: 6px;
    background: rgba(0, 0, 0, 0.65);
    color: #fff;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    font-family: var(--font-body);
  }
  .ke-gallery-captions {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .ke-gallery-captions li {
    font-family: var(--font-body);
    font-size: var(--font-body-size);
    line-height: var(--prose-line-height);
    color: rgba(255, 255, 255, 0.92);
    margin-bottom: 0.6rem;
  }
  .ke-gallery-captions .num {
    font-weight: 700;
    color: #fff;
  }

  /* K&E in-line floated figures — Jay's original Weebly build floated one
     image per text box at half or third width, with text justifying
     around it; this replicates that instead of full-width block images
     breaking up a single column. */
  .ke-figure {
    margin-bottom: 1rem;
  }
  .ke-figure :global(img) {
    margin: 0;
  }
  .ke-figure-caption {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-prose-text);
    margin-top: 0.4rem;
  }
  .ke-figure-left {
    float: left;
    width: 46%;
    margin: 0.3rem 1.5rem 1rem 0;
  }
  .ke-figure-right {
    float: right;
    width: 46%;
    margin: 0.3rem 0 1rem 1.5rem;
  }
  .ke-figure-third.ke-figure-left,
  .ke-figure-third.ke-figure-right {
    width: 31%;
  }
  .ke-clear {
    clear: both;
  }
  .ke-figure-row {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .ke-figure-row .ke-figure {
    flex: 1;
    margin-bottom: 0;
  }

  article :global(h2),
  article :global(h3) {
    clear: both;
  }

  @media (max-width: 700px) {
    .ke-figure-left,
    .ke-figure-right {
      float: none;
      width: 100%;
      margin-left: 0;
      margin-right: 0;
    }
    .ke-figure-row {
      flex-direction: column;
      gap: 0;
    }
  }

  /* K&E landing-page two-column intro (title/author's note/TOC at left,
     Introduction at right), matching the original article's layout for
     that section. Width split is intentionally uneven so the shorter
     left column (fixed-height TOC list) and the longer right column
     (Introduction prose) end at roughly the same height. */
  .ke-columns {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    margin: 1.5rem 0;
  }
  .ke-col-left {
    flex: 0 0 40%;
  }
  .ke-col-right {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 700px) {
    .ke-columns {
      flex-direction: column;
    }
    .ke-col-left,
    .ke-col-right {
      flex-basis: auto;
    }
  }
</style>
